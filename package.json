{
  "name": "queueless-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "reset": "lsof -ti:8081 | xargs kill -9 2>/dev/null; echo 'Port 8081 freed'",
    "bundle": "expo export --platform ios --output-dir /tmp/queueless-bundle 2>&1 && echo 'Bundle OK'",
    "check": "npm run types && npm run bundle",
    "types": "supabase gen types typescript --linked --workdir . > src/types/database.ts",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/ui": "~0.2.0-beta.9",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/aspect-ratio": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/context-menu": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/hover-card": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/menubar": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/progress": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.107.0",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "^0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.14.0",
    "lucide-react-native": "^1.17.0",
    "nativewind": "4.2.5",
    "react": "19.1.0",
    "react-hook-form": "^7.77.0",
    "react-native": "0.81.5",
    "react-native-fast-confetti": "^2.0.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": "^0.5.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "main": "expo-router/entry",
  "private": true
}
